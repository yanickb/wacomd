#!/usr/bin/env bash
# Identités de signature — sourcé par les scripts build-app.sh,
# build-installer.sh et notarize.sh. Modifier ici sans toucher les autres.

# Developer ID Application — signe les .app et binaires distribués hors App Store.
SIGN_APP="Developer ID Application: yanick blancho (4U3987KC72)"

# Developer ID Installer — signe les .pkg.
SIGN_PKG="Developer ID Installer: yanick blancho (4U3987KC72)"

# Team ID Apple (10 caractères) — apparaît à plusieurs endroits.
TEAM_ID="4U3987KC72"

# Profil keychain utilisé par `xcrun notarytool` pour la notarisation.
# Configurable une seule fois avec :
#   xcrun notarytool store-credentials wacomd-notary \
#       --apple-id    "ton@apple.id" \
#       --team-id     "4U3987KC72" \
#       --password    "<app-specific password — appleid.apple.com>"
NOTARY_PROFILE="wacomd-notary"
